{
  "manifest_version": 3,
  "name": "ERP 機位報告",
  "version": "1.0",
  "description": "一鍵擷取 ERP SearchList 機位資料，產出即將成團分析報告",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://gitberp.liontravel.com/*"
  ],
  "action": {
    "default_title": "ERP 機位報告"
  },
  "background": {
    "service_worker": "background.js"
  }
}
